# --- OpenSearch (must support the kNN plugin) ---
# Full connection URL including credentials, e.g.
#   https://user:PASSWORD@host-xxxx.example.com:12345
# Options that support kNN: Aiven OpenSearch, AWS OpenSearch Service free tier,
# or a self-hosted OpenSearch (Docker) for dev. See RAG.md for tradeoffs.
OPENSEARCH_URL=
OPENSEARCH_INDEX=portfolio_corpus
# Visitor feedback lands in its own index in the same domain (auto-created).
OPENSEARCH_FEEDBACK_INDEX=feedback

# --- LLM generation (NVIDIA NIM, open models, free credits) ---
# Get a key at https://build.nvidia.com (OpenAI-compatible endpoint).
NIM_API_KEY=
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL=meta/llama-3.1-70b-instruct
NIM_FALLBACK_MODEL=meta/llama-3.1-8b-instruct

# --- Embeddings (NVIDIA NIM by default) ---
# Indexing and query MUST use the same model. nv-embedqa needs input_type,
# which is sent automatically (set EMBEDDING_INPUT_TYPE=false for OpenAI models).
EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5
EMBEDDING_DIM=1024
EMBEDDING_INPUT_TYPE=true
# Defaults to the NIM endpoint/key above; override to use a different provider.
# EMBEDDING_BASE_URL=
# EMBEDDING_API_KEY=

# --- Optional OpenAI fallback (leave blank to stay all-NVIDIA) ---
OPENAI_API_KEY=
OPENAI_FALLBACK_MODEL=gpt-4o-mini

# --- Retrieval tuning ---
RETRIEVAL_TOP_K=4
# Top cosine similarity below this triggers the guardrail refusal (no fabrication).
LOW_CONFIDENCE_THRESHOLD=0.28
